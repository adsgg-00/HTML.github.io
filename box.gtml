<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Page Task</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4;
        }

        /* Container for the table */
        .container {
            background: white;
            padding: 20px;
            border: 1px solid #ddd;
            box-shadow: 2px 2px 10px rgba(0,0,0,0.1);
            width: fit-content;
        }

        /* Table Styling */
        table {
            border-collapse: collapse;
            width: 300px;
            text-align: left;
        }

        th, td {
            border: 1px solid #333;
            padding: 8px;
        }

        /* Header colors */
        th {
            background-color: #808080;
            color: white;
        }

        /* Alternate row colors based on the image */
        tr:nth-child(even) {
            background-color: yellow;
        }

        tr:nth-child(odd) {
            background-color: white;
        }

        /* Fixed Div Styling */
        .fixed-box {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 150px;
            height: 150px;
            border: 3px solid #76b900; /* Green border */
            padding: 10px;
            background-color: white;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="container">
        <table>
            <thead>
                <tr>
                    <th>Firstname</th>
                    <th>Lastname</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>1</td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>2</td>
                </tr>
                <tr>
                    <td>3</td>
                    <td>3</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="fixed-box">
        This div element has position: fixed;
    </div>

</body>
</html>
